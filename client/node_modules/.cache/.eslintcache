  d=\"M4 12H20\"\r\n                stroke=\"currentColor\"\r\n                strokeWidth=\"1.5\"\r\n                strokeLinecap=\"round\"\r\n                strokeLinejoin=\"round\"\r\n              />\r\n              <path\r\n                d=\"M4 18H20\"\r\n                stroke=\"currentColor\"\r\n                strokeWidth=\"1.5\"\r\n                strokeLinecap=\"round\"\r\n                strokeLinejoin=\"round\"\r\n              />\r\n            </svg>\r\n          </button>\r\n          <button\r\n            id=\"close\"\r\n            aria-label=\"close\"\r\n            onClick={() => setShow(!show)}\r\n            className={`${\r\n              show ? \"hidden\" : \"\"\r\n            } focus:outline-none focus:ring-2  `}\r\n          >\r\n            <svg\r\n              className=\"text-indigo-200\"\r\n              width={24}\r\n              height={24}\r\n              viewBox=\"0 0 24 24\"\r\n              fill=\"none\"\r\n              xmlns=\"http://www.w3.org/2000/svg\"\r\n            >\r\n              <path\r\n                d=\"M18 6L6 18\"\r\n                stroke=\"currentColor\"\r\n                strokeWidth=\"1.5\"\r\n                strokeLinecap=\"round\"\r\n                strokeLinejoin=\"round\"\r\n              />\r\n              <path\r\n                d=\"M6 6L18 18\"\r\n                stroke=\"currentColor\"\r\n                strokeWidth=\"1.5\"\r\n                strokeLinecap=\"round\"\r\n                strokeLinejoin=\"round\"\r\n              />\r\n            </svg>\r\n          </button>\r\n        </div>\r\n      </div>\r\n      {/* Nav version pc */}\r\n      <div\r\n        id=\"Main\"\r\n        className={`${\r\n          show ? \"-translate-x-full\" : \"translate-x-0 \"\r\n        } bg-[#4D148C] transform  xl:translate-x-0 shadow xl:rounded-r fixed h-[100vh] sm:h-full  top-22 sm:z-50 z-50 hover:overflow-auto  ease-in-out transition duration-500 flex justify-start items-start w-full sm:w-64 flex-col px-0 pb-24 sm:pb-0`}\r\n      >\r\n        <button className=\"hidden focus:outline-none hover:text-indigo-200 focus:text-indigo-200 text-white sm:flex justify-start p-6 items-center space-x-0  w-full\">\r\n          <img\r\n            src=\"/logo/logo-no-text.png\"\r\n            alt=\"\"\r\n            className=\"w-[84px] h-[44px]\"\r\n            id=\"logo-no-text\"\r\n          />\r\n          <img\r\n            src=\"/logo/logo-title.png\"\r\n            alt=\"\"\r\n            className=\"w-[204px] h-[54px] mb-3\"\r\n          />\r\n        </button>\r\n        {/* Avatar */}\r\n        <div className=\"w-full sm:px-5 px-10 sm:py-0 py-5\">\r\n          <div\r\n            className=\"px-6 text-indigo-200  w-full bg-[#37145d] rounded-2xl py-2\"\r\n            id=\"avatar\"\r\n          >\r\n            <div class=\"flex flex-col items-center mb-2 -mx-2\">\r\n              {userInfo === null ? (\r\n                \"\"\r\n              ) : (\r\n                <img\r\n                  class=\"object-cover w-24 h-24 mx-2 rounded-full\"\r\n                  src={\r\n                    userInfo.imgUrl === null\r\n                      ? \"/images/user.jpeg\"\r\n                      : userInfo.imgUrl\r\n                  }\r\n                />\r\n              )}\r\n              <h4 class=\"mx-2 mt-2 font-medium\">\r\n                {userInfo === null ? \"chargement . . .\" : userInfo.username}\r\n              </h4>\r\n              <p class=\"mx-2 mt-1 text-sm font-medium \">\r\n                {userInfo === null ? \"\" : userInfo.email}\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        {/* Dashboard routes start */}\r\n        <div className=\"   mt-4 flex flex-col px-6 justify-start items-center w-full   \">\r\n          {/* Dashboard */}\r\n          <button className=\"focus:outline-none focus:text-white  flex jusitfy-start   hover:text-white  text-indigo-200  rounded py-3  items-center space-x-6 w-full \">\r\