urce":null},"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\index.js",[],[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\App.js",["155"],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\reportWebVitals.js",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\routes\\Home.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\layouts\\Navbar.jsx",["156"],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components\\PanelBlocs.jsx",["157","158"],[],"import React, { useEffect, useState } from \"react\";\r\nimport axios from \"axios\";\r\n\r\nexport default function PanelBlocs() {\r\n  const [data1, setData1] = useState([]);\r\n  const [data2, setData2] = useState([]);\r\n\r\n  useEffect(() => {\r\n    function fetchData() {\r\n      const response1 = axios\r\n        .get(\"http://localhost:4000/order/\")\r\n        .then((res) => setData1(res.data));\r\n      const response2 = axios\r\n        .get(\"http://localhost:4000/user/\")\r\n        .then((res) => setData2(res.data));\r\n    }\r\n\r\n    fetchData();\r\n  }, []);\r\n\r\n  const valid = data1.filter((item) => item.status === true);\r\n  const invalid = data1.filter((item) => item.status === false);\r\n  const validuser = data2.filter((item) => item.isAdmin === false);\r\n\r\n  return (\r\n    <div className=\" py-12 rounded-xl p-12 bg-[#1507231a]\">\r\n      <div>\r\n        <div className=\"flex md:flex-row  md:flex-nowrap flex-wrap flex-col w-full h-full md:space-x-12 md:space-y-0 space-y-12 rounded-xl p-12\">\r\n          {/* Panel 1 */}\r\n          <div className=\"md:w-1/3 w-full bg-white flex justify-center items-center rounded-xl space-x-1 sm:space-x-4 lg:space-x-8 py-8 px-5 h-44\">\r\n            <img src=\"/images/order-1.png\" alt=\"\" className=\"w-16 h-16 mt-2\" />\r\n            <div>\r\n              <p className=\"mb-2 font-semibold font-mono text-sm\">\r\n                Nombres total de livraisons\r\n              </p>\r\n              <strong className=\"pl-2 text-xl font-mono text-[#5d6bd1]\">\r\n                {data1.length}\r\n              </strong>\r\n            </div>\r\n          </div>\r\n          {/* Panel 2 */}\r\n          <div className=\"md:w-1/3 w-full bg-white flex justify-center items-center rounded-xl space-x-1 sm:space-x-4 lg:space-x-8 py-8 px-5 h-44\">\r\n            <img src=\"/images/order.png\" alt=\"\" className=\"w-16 h-16 mt-2\" />\r\n            <div>\r\n              <p className=\"mb-2 font-semibold font-mono text-sm\">\r\n                Nombres de livraisons effectuées\r\n              </p>\r\n              <strong className=\"pl-2 text-xl font-mono text-[#5d6bd1]\">\r\n                {valid.length}\r\n              </strong>\r\n            </div>\r\n          </div>\r\n          {/* Panel 3 */}\r\n          <div className=\"md:w-1/3 w-full bg-white flex justify-center items-center rounded-xl  space-x-1 sm:space-x-4 lg:space-x-8 py-8 px-5 h-44\">\r\n            <img\r\n              src=\"/images/video-call.png\"\r\n              alt=\"\"\r\n              className=\"w-16 h-16 mt-2\"\r\n            />\r\n            <div>\r\n              <p className=\"mb-2 font-semibold font-mono text-sm\">\r\n                Nombres de total d'utilisateurs\r\n              </p>\r\n              <strong className=\"pl-2 text-xl font-mono text-[#5d6bd1]\">\r\n                {validuser.length}\r\n              </strong>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div className=\"px-12\">\r\n        <div className=\"md:w-1/3 w-full bg-white flex justify-center items-center rounded-xl  space-x-1 sm:space-x-4 lg:space-x-8 py-8 px-5 h-44\">\r\n          <img src=\"/images/suivi.png\" alt=\"\" className=\"w-16 h-16 mt-2\" />\r\n          <div>\r\n            <p className=\"mb-2 font-semibold font-mono text-sm\">\r\n              Nombres de total de livraisons en cours\r\n            </p>\r\n            <strong className=\"pl-2 text-xl font-mono text-[#5d6bd1]\">{invalid.length}</strong>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n",[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components\\Table.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components\\OrderDetails.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\layouts\\SearchBar.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\layouts\\Footer.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\routes\\AllOrder.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components\\OrderTable.jsx",["159","160"],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\routes\\Administration.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components\\AdminTable.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components\\SignupSection.jsx",["161","162","163","164"],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\routes\\Signup.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\routes\\Login.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components\\LoginSection.jsx",["165"],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components-two\\SignupUser.jsx",["166","167","168"],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\routes\\AllUser.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components\\UserSection.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\services\\account.service.js",["169","170","171"],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components-two\\Order.jsx",["172"],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\components-two\\PanelUser.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\src\\routes\\ProfileBlog.jsx",[],[],"C:\\Users\\Evans\\Desktop\\dashboard-fimat\\client\\sr